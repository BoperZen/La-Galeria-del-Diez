@model IEnumerable<La_Galeria_del_Diez.Application.DTOs.AuctionDTO>

@{
    ViewData["Title"] = "Payments";
}

<div class="min-h-screen bg-background py-10">
    <div class="container mx-auto px-4 max-w-4xl">
        <h1 class="text-4xl font-bold text-foreground mb-3 flex items-center">
            <i class="bi bi-credit-card text-primary mr-3"></i>
            Pending payments
        </h1>

        @if (TempData["PaymentSuccess"] is string successMessage)
        {
            <div class="mb-4 bg-green-500/10 border border-green-500/40 text-green-300 rounded-lg p-3 font-semibold">
                @successMessage
            </div>
        }

        @if (TempData["PaymentError"] is string errorMessage)
        {
            <div class="mb-4 bg-red-500/10 border border-red-500/40 text-red-300 rounded-lg p-3 font-semibold">
                @errorMessage
            </div>
        }

        <div class="bg-card rounded-xl border border-border p-6 shadow-lg">
            @if (Model != null && Model.Any())
            {
                <div class="space-y-4">
                    @foreach (var auction in Model)
                    {
                        var leadingBid = auction.Biddings?
                            .OrderByDescending(b => b.Amount)
                            .ThenByDescending(b => b.RegistrationDate)
                            .FirstOrDefault();
                        var buyerUserId = auction.AutionWinner ?? leadingBid?.IdUser ?? 0;
                        var winnerBid = auction.Biddings?
                            .Where(b => b.IdUser == buyerUserId)
                            .OrderByDescending(b => b.Amount)
                            .ThenByDescending(b => b.RegistrationDate)
                            .FirstOrDefault();
                        var amount = winnerBid?.Amount ?? leadingBid?.Amount ?? auction.BasePrice;

                        <div class="rounded-lg border border-border p-4 bg-muted/20">
                            <div class="grid grid-cols-1 md:grid-cols-6 gap-4">
                                <div>
                                    <p class="text-xs text-muted-foreground">Auction</p>
                                    <p class="font-semibold text-foreground">@(auction.Object?.Name ?? $"Auction #{auction.Id}") (#@auction.Id)</p>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Buyer user</p>
                                    <p class="font-semibold text-foreground">@buyerUserId</p>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Amount</p>
                                    <p class="font-semibold text-primary">@amount.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))</p>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Date</p>
                                    <p class="font-semibold text-foreground">@auction.EndDate.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Payment status</p>
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-yellow-500/20 text-yellow-300 border border-yellow-500/30">
                                        Pending
                                    </span>
                                </div>
                                <div class="flex items-end md:justify-end">
                                    <a asp-action="Pay"
                                       asp-route-id="@auction.Id"
                                       class="inline-flex items-center px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold">
                                        <i class="bi bi-credit-card-2-front mr-2"></i>
                                        Pay
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8">
                    <i class="bi bi-check-circle text-5xl text-muted-foreground"></i>
                    <p class="mt-3 text-foreground font-semibold">There are no pending payments for this user.</p>
                </div>
            }
        </div>
    </div>
</div>
