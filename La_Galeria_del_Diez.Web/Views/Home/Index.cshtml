@{
    ViewData["Title"] = "Home - Jersey Auctions";
}

<!-- Hero Section con Imagen de Fondo -->
<section class="relative h-[700px] overflow-hidden">
    <!-- Background Image Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-background via-background/95 to-background/80 z-10"></div>
    
    <!-- Imagen de fondo -->
    <div class="absolute inset-0 bg-cover bg-center opacity-30" 
         style="background-image: url('https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=1920');">
    </div>

    <!-- Contenido del Hero -->
    <div class="relative z-20 container mx-auto my-2 px-4 h-full flex items-center pb-4 pt-4">
        <div class="max-w-3xl ">
            <div class="inline-flex items-center px-4 py-2 bg-primary/20 border border-primary/30 rounded-full text-primary text-sm font-medium mb-6">
                <span class="relative flex h-2 w-2 mr-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                </span>
                Live auctions
            </div>
            
            <h1 class="text-6xl md:text-7xl font-bold text-foreground mb-6 leading-tight">
                Legendary<br/>
                <span class="text-primary">Jerseys</span><br/>
                Within Reach
            </h1>
            
            <p class="text-xl text-muted-foreground mb-8 leading-relaxed">
                Join exclusive jersey auctions from the greatest teams and players in the world.
                Authenticity guaranteed.
            </p>

            <div class="flex flex-wrap gap-4">
                <a asp-controller="Subasta" asp-action="Index" 
                   class="inline-flex items-center px-8 py-4 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all duration-200 font-bold text-lg shadow-xl hover:shadow-2xl hover:scale-105">
                    <i class="bi bi-hammer mr-3"></i>
                    View Active Auctions
                </a>
                <a asp-controller="Object" asp-action="Index" 
                   class="inline-flex items-center px-8 py-4 border-2 border-primary text-primary rounded-lg hover:bg-primary hover:text-primary-foreground transition-all duration-200 font-bold text-lg">
                    <i class="bi bi-collection mr-3"></i>
                    Explore Catalog
                </a>
            </div>

            <!-- Stats -->
            <div class="grid grid-cols-3 gap-8 mt-12 pt-8 border-t border-border">
                <div>
                    <div class="text-3xl font-bold text-primary">1,234</div>
                    <div class="text-sm text-muted-foreground">Jerseys Sold</div>
                </div>
                <div>
                    <div class="text-3xl font-bold text-primary">45</div>
                    <div class="text-sm text-muted-foreground">Active Auctions</div>
                </div>
                <div>
                    <div class="text-3xl font-bold text-primary">890</div>
                    <div class="text-sm text-muted-foreground">Active Users</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Auctions -->
<section class="py-16 bg-background">
    <div class="container mx-auto px-4">
        <div class="flex items-center justify-between mb-12">
            <div>
                <h2 class="text-4xl font-bold text-foreground mb-2">Featured Auctions</h2>
                <p class="text-muted-foreground">The most sought-after jerseys right now</p>
            </div>
            <a asp-controller="Subasta" asp-action="Index" 
               class="text-primary hover:text-secondary font-semibold flex items-center">
                View all
                <i class="bi bi-arrow-right ml-2"></i>
            </a>
        </div>

        <!-- Jersey Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Card 1 -->
            <div class="group bg-card rounded-xl shadow-lg border border-border overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105">
                <div class="relative h-64 bg-muted overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=400" 
                         alt="Camiseta" 
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
                    <div class="absolute top-3 right-3">
                        <span class="px-3 py-1 bg-red-500/90 text-white text-xs font-bold rounded-full">
                            LIVE AUCTION
                        </span>
                    </div>
                </div>
                <div class="p-4">
                    <div class="text-xs text-primary font-semibold mb-2">ARGENTINA</div>
                    <h3 class="font-bold text-foreground mb-2 line-clamp-2">Argentina Jersey 1986 - Maradona #10</h3>
                    <div class="flex items-center justify-between mb-3">
                        <div>
                            <div class="text-xs text-muted-foreground">Current bid</div>
                            <div class="text-xl font-bold text-primary">$2,450</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-muted-foreground">Ends in</div>
                            <div class="text-sm font-bold text-destructive">2h 15m</div>
                        </div>
                    </div>
                    <button class="w-full px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-secondary transition-all font-medium">
                        Bid Now
                    </button>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="group bg-card rounded-xl shadow-lg border border-border overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105">
                <div class="relative h-64 bg-muted overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=400" 
                         alt="Camiseta" 
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
                    <div class="absolute top-3 right-3">
                        <span class="px-3 py-1 bg-green-500/90 text-white text-xs font-bold rounded-full">
                            NEW
                        </span>
                    </div>
                </div>
                <div class="p-4">
                    <div class="text-xs text-accent font-semibold mb-2">BRASIL</div>
                    <h3 class="font-bold text-foreground mb-2 line-clamp-2">Brazil Jersey 2002 - Ronaldo #9</h3>
                    <div class="flex items-center justify-between mb-3">
                        <div>
                            <div class="text-xs text-muted-foreground">Current bid</div>
                            <div class="text-xl font-bold text-primary">$1,890</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-muted-foreground">Ends in</div>
                            <div class="text-sm font-bold text-destructive">5h 42m</div>
                        </div>
                    </div>
                    <button class="w-full px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-secondary transition-all font-medium">
                        Bid Now
                    </button>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="group bg-card rounded-xl shadow-lg border border-border overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105">
                <div class="relative h-64 bg-muted overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1551958219-acbc608c6377?w=400" 
                         alt="Camiseta" 
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
                </div>
                <div class="p-4">
                    <div class="text-xs text-primary font-semibold mb-2">ESPAÑA</div>
                    <h3 class="font-bold text-foreground mb-2 line-clamp-2">Spain Jersey 2010 - Iniesta #6</h3>
                    <div class="flex items-center justify-between mb-3">
                        <div>
                            <div class="text-xs text-muted-foreground">Current bid</div>
                            <div class="text-xl font-bold text-primary">$3,200</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-muted-foreground">Ends in</div>
                            <div class="text-sm font-bold text-destructive">1h 08m</div>
                        </div>
                    </div>
                    <button class="w-full px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-secondary transition-all font-medium">
                        Bid Now
                    </button>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="group bg-card rounded-xl shadow-lg border border-border overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105">
                <div class="relative h-64 bg-muted overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1574629810360-7efbbe195018?w=400" 
                         alt="Camiseta" 
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
                    <div class="absolute top-3 right-3">
                        <span class="px-3 py-1 bg-yellow-500/90 text-gray-900 text-xs font-bold rounded-full">
                            ENDING SOON
                        </span>
                    </div>
                </div>
                <div class="p-4">
                    <div class="text-xs text-accent font-semibold mb-2">FRANCIA</div>
                    <h3 class="font-bold text-foreground mb-2 line-clamp-2">France Jersey 1998 - Zidane #10</h3>
                    <div class="flex items-center justify-between mb-3">
                        <div>
                            <div class="text-xs text-muted-foreground">Current bid</div>
                            <div class="text-xl font-bold text-primary">$2,750</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-muted-foreground">Ends in</div>
                            <div class="text-sm font-bold text-destructive">45m</div>
                        </div>
                    </div>
                    <button class="w-full px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-secondary transition-all font-medium">
                        Bid Now
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-16 bg-muted/30">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-4xl font-bold text-foreground mb-4">How It Works</h2>
            <p class="text-muted-foreground text-lg">Join in 3 simple steps</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Step 1 -->
            <div class="text-center">
                <div class="w-20 h-20 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-6 border-4 border-primary">
                    <span class="text-3xl font-bold text-primary">1</span>
                </div>
                <h3 class="text-xl font-bold text-foreground mb-3">Explore the Catalog</h3>
                <p class="text-muted-foreground">
                    Browse our exclusive collection of authentic jerseys from legendary teams and players.
                </p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
                <div class="w-20 h-20 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-6 border-4 border-accent">
                    <span class="text-3xl font-bold text-accent">2</span>
                </div>
                <h3 class="text-xl font-bold text-foreground mb-3">Place Your Bid</h3>
                <p class="text-muted-foreground">
                    Join the auction by placing your bid. Watch other users' bids in real time.
                </p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
                <div class="w-20 h-20 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-6 border-4 border-primary">
                    <span class="text-3xl font-bold text-primary">3</span>
                </div>
                <h3 class="text-xl font-bold text-foreground mb-3">Win the Jersey!</h3>
                <p class="text-muted-foreground">
                    If you are the top bidder when the auction ends, the jersey is yours. Get it delivered to your door.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="py-20 bg-gradient-to-r from-primary/10 via-accent/10 to-primary/10">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-5xl font-bold text-foreground mb-6">
                Ready to Get Started?
            </h2>
            <p class="text-xl text-muted-foreground mb-8">
                Join thousands of collectors and get the most exclusive jerseys in sports.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
                <a asp-controller="Login" asp-action="Index" 
                   class="inline-flex items-center px-10 py-4 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all duration-200 font-bold text-lg shadow-xl hover:shadow-2xl hover:scale-105">
                    Sign Up Now
                    <i class="bi bi-arrow-right ml-3"></i>
                </a>
                <a asp-controller="Subasta" asp-action="Index" 
                   class="inline-flex items-center px-10 py-4 border-2 border-primary text-primary rounded-lg hover:bg-primary hover:text-primary-foreground transition-all duration-200 font-bold text-lg">
                    View Auctions
                </a>
            </div>
        </div>
    </div>
</section>
