<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - La Galería del Diez</title>

    <!-- Preconnect -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://code.jquery.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <!-- Tailwind CSS con colores -->
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />

    <!-- jQuery UI CSS -->
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="~/lib/sweetalert2/dist/sweetalert2.min.css" />

    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="flex flex-col min-h-screen bg-background text-foreground">

    <!-- Navbar -->
    <header>
        @await Html.PartialAsync("_Menu")
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- Footer -->
    @await Html.PartialAsync("_Footer")

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>
    <script src="~/lib/sweetalert2/dist/sweetalert2.all.js"></script>

    <!-- SWEETALERT NOTIFICATION -->
    @if (TempData["Notificacion"] != null || ViewBag.Notificacion != null)
    {
        var notificacion = TempData["Notificacion"] ?? ViewBag.Notificacion;
        <script type="text/javascript">
            const payload = @Html.Raw(notificacion);
            if (payload) {
                Swal.fire(payload);
            }
        </script>
    }

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
