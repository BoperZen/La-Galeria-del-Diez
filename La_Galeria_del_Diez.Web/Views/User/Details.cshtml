@model La_Galeria_del_Diez.Application.DTOs.UserDTO

@{
    ViewData["Title"] = "Detalle de Usuario";
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4 max-w-6xl">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center space-x-4">
                <a asp-action="Index" class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-muted hover:bg-muted/80 transition-colors">
                    <i class="bi bi-arrow-left text-xl"></i>
                </a>
                <div>
                    <h1 class="text-4xl font-bold text-foreground">Detalle de Usuario</h1>
                    <p class="text-muted-foreground">Información completa del usuario</p>
                </div>
            </div>
            <div class="flex gap-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" 
                   class="inline-flex items-center px-6 py-3 bg-accent text-accent-foreground rounded-lg hover:opacity-90 transition-all font-semibold shadow-lg">
                    <i class="bi bi-pencil mr-2"></i>
                    Editar
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" 
                   class="inline-flex items-center px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-all font-semibold shadow-lg">
                    <i class="bi bi-trash mr-2"></i>
                    Eliminar
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Profile Card -->
            <div class="lg:col-span-1">
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden sticky top-24">
                    <!-- Profile Header -->
                    <div class="bg-gradient-to-br from-primary/20 to-accent/20 p-8 text-center border-b border-border">
                        <div class="w-32 h-32 bg-primary/30 rounded-full flex items-center justify-center mx-auto mb-4 border-4 border-primary">
                            <span class="text-6xl font-bold text-primary">
                                @(string.IsNullOrEmpty(Model.Username) ? "U" : Model.Username.Substring(0, 1).ToUpper())
                            </span>
                        </div>
                        <h2 class="text-2xl font-bold text-foreground mb-2">@Model.Username</h2>
                        <p class="text-muted-foreground text-sm mb-4">@Model.Email</p>
                        
                        @if (Model.UserState == true)
                        {
                            <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-green-500/20 text-green-400 border border-green-500/30">
                                <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
                                Usuario Activo
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-red-500/20 text-red-400 border border-red-500/30">
                                <span class="w-2 h-2 bg-red-400 rounded-full mr-2"></span>
                                Usuario Inactivo
                            </span>
                        }
                    </div>

                    <!-- Quick Stats -->
                    <div class="p-6 space-y-4">
                        <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                                    <i class="bi bi-shield-check text-primary"></i>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Rol</p>
                                    <p class="font-semibold text-foreground">
                                        @(Model.IdRolNavigation?.Description ?? "Sin Rol")
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center">
                                    <i class="bi bi-calendar text-accent"></i>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Miembro desde</p>
                                    <p class="font-semibold text-foreground">@Model.RegistrationDate.ToString("dd MMM yyyy")</p>
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                                    <i class="bi bi-hash text-primary"></i>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">ID de Usuario</p>
                                    <p class="font-semibold text-foreground font-mono">#@Model.Id</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details Card -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Information Section -->
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden">
                    <div class="bg-muted px-6 py-4 border-b border-border">
                        <h3 class="text-lg font-bold text-foreground flex items-center">
                            <i class="bi bi-info-circle mr-2"></i>
                            Información Personal
                        </h3>
                    </div>
                    <div class="p-6">
                        <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-person mr-2"></i>
                                    Nombre de Usuario
                                </dt>
                                <dd class="text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg">
                                    @Model.Username
                                </dd>
                            </div>

                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-envelope mr-2"></i>
                                    Email
                                </dt>
                                <dd class="text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg">
                                    @Model.Email
                                </dd>
                            </div>

                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-shield-lock mr-2"></i>
                                    Contraseña
                                </dt>
                                <dd class="text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg font-mono">
                                    ••••••••••••
                                </dd>
                            </div>

                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-calendar-event mr-2"></i>
                                    Fecha de Registro
                                </dt>
                                <dd class="text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg">
                                    @Model.RegistrationDate.ToString("dd/MM/yyyy HH:mm")
                                </dd>
                            </div>
                        </dl>
                    </div>
                </div>

                <!-- Account Details -->
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden">
                    <div class="bg-muted px-6 py-4 border-b border-border">
                        <h3 class="text-lg font-bold text-foreground flex items-center">
                            <i class="bi bi-gear mr-2"></i>
                            Configuración de Cuenta
                        </h3>
                    </div>
                    <div class="p-6">
                        <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-shield-check mr-2"></i>
                                    Rol Asignado
                                </dt>
                                <dd>
                                    <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-primary/20 text-primary border border-primary/30">
                                        <i class="bi bi-star-fill mr-2"></i>
                                        @(Model.IdRolNavigation?.Description ?? "Sin Rol")
                                    </span>
                                </dd>
                            </div>

                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-toggle-on mr-2"></i>
                                    Estado de la Cuenta
                                </dt>
                                <dd>
                                    @if (Model.UserState == true)
                                    {
                                        <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-green-500/20 text-green-400 border border-green-500/30">
                                            <i class="bi bi-check-circle-fill mr-2"></i>
                                            Activa
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-red-500/20 text-red-400 border border-red-500/30">
                                            <i class="bi bi-x-circle-fill mr-2"></i>
                                            Inactiva
                                        </span>
                                    }
                                </dd>
                            </div>

                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-clock-history mr-2"></i>
                                    Días como Miembro
                                </dt>
                                <dd class="text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg">
                                    @((DateTime.Now - Model.RegistrationDate).Days) días
                                </dd>
                            </div>

                            <div>
                                <dt class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-key mr-2"></i>
                                    ID del Rol
                                </dt>
                                <dd class="text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg font-mono">
                                    #@Model.IdRol
                                </dd>
                            </div>
                        </dl>
                    </div>
                </div>

                <!-- Activity Timeline -->
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden">
                    <div class="bg-muted px-6 py-4 border-b border-border">
                        <h3 class="text-lg font-bold text-foreground flex items-center">
                            <i class="bi bi-clock-history mr-2"></i>
                            Actividad Reciente
                        </h3>
                    </div>
                    <div class="p-6">
                        <div class="text-center py-8 text-muted-foreground">
                            <i class="bi bi-info-circle text-4xl mb-3"></i>
                            <p>No hay actividad reciente registrada</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-8 flex justify-between items-center">
            <a asp-action="Index" 
               class="inline-flex items-center px-6 py-3 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                <i class="bi bi-arrow-left mr-2"></i>
                Volver a la Lista
            </a>
            <div class="flex gap-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" 
                   class="inline-flex items-center px-6 py-3 bg-accent text-accent-foreground rounded-lg hover:opacity-90 transition-all font-semibold shadow-lg">
                    <i class="bi bi-pencil mr-2"></i>
                    Editar Usuario
                </a>
            </div>
        </div>
    </div>
</div>
