@using X.PagedList
@model IPagedList<La_Galeria_del_Diez.Application.DTOs.UserDTO>

@{
    ViewData["Title"] = "Users";
    var editedUserId = TempData["EditedUserId"]?.ToString();
}

<style>
    @@keyframes userRowSlowPulse {
        0%, 100% {
            background-color: rgba(59, 130, 246, 0.03);
        }
        50% {
            background-color: rgba(59, 130, 246, 0.12);
        }
    }

    .user-row-pulse td {
        animation: userRowSlowPulse 2.4s ease-in-out infinite;
    }
</style>

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <div>
                <h1 class="text-4xl font-bold text-foreground mb-2">User Management</h1>
                <p class="text-muted-foreground">Manage platform users</p>
            </div>
            <a asp-action="Create"
               class="inline-flex items-center px-4 py-2 bg-primary text-primary-foreground rounded-lg font-semibold hover:bg-secondary transition-colors">
                <i class="bi bi-person-plus mr-2"></i>
                Create user
            </a>
        </div>

        <!-- Users Table -->
        <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-muted border-b border-border">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-foreground uppercase tracking-wider">
                                User
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-foreground uppercase tracking-wider">
                                Role
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-foreground uppercase tracking-wider">
                                Status
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-foreground uppercase tracking-wider">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-muted/50 transition-colors duration-150"
                                data-user-id="@item.Id">
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 bg-primary/20 rounded-full flex items-center justify-center mr-3">
                                            <span class="text-primary font-bold">@item.Username.Substring(0, 1).ToUpper()</span>
                                        </div>
                                        <div>
                                            <div class="text-sm font-medium text-foreground">@item.Username</div>
                                            <div class="text-xs text-muted-foreground">ID: @item.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/20 text-primary border border-primary/30">
                                        <i class="bi bi-shield-check mr-1"></i>
                                        @item.IdRolNavigation.Description
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.UserState == true)
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-500/20 text-green-400 border border-green-500/30">
                                            <span class="w-2 h-2 bg-green-400 rounded-full mr-2"></span>
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-500/20 text-red-400 border border-red-500/30">
                                            <span class="w-2 h-2 bg-red-400 rounded-full mr-2"></span>
                                            Inactive
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" 
                                           class="inline-flex items-center justify-center p-2 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors border border-primary/20"
                                           title="View details">
                                            <i class="bi bi-eye text-lg"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" 
                                           class="inline-flex items-center justify-center p-2 rounded-lg bg-accent/10 text-accent hover:bg-accent/20 transition-colors border border-accent/20"
                                           title="Edit">
                                            <i class="bi bi-pencil text-lg"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.PageCount > 1)
        {
            <div class="mt-6 flex items-center justify-between gap-4 flex-wrap">
                <div class="text-sm text-muted-foreground">
                    Page @Model.PageNumber of @Model.PageCount
                </div>
                <div class="inline-flex items-center gap-1">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.PageNumber - 1)"
                           class="px-3 py-2 rounded-md border border-border bg-card text-foreground hover:bg-muted transition-colors">
                            Previous
                        </a>
                    }

                    @for (int i = 1; i <= Model.PageCount; i++)
                    {
                        <a asp-action="Index" asp-route-page="@i"
                           class="px-3 py-2 rounded-md border @(i == Model.PageNumber ? "border-primary bg-primary text-primary-foreground" : "border-border bg-card text-foreground hover:bg-muted") transition-colors">
                            @i
                        </a>
                    }

                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.PageNumber + 1)"
                           class="px-3 py-2 rounded-md border border-border bg-card text-foreground hover:bg-muted transition-colors">
                            Next
                        </a>
                    }
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="bg-card rounded-xl shadow-2xl border border-border p-12 text-center mt-6">
                <div class="max-w-md mx-auto">
                    <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="bi bi-people text-4xl text-primary"></i>
                    </div>
                    <h3 class="text-xl font-bold text-foreground mb-2">No users registered</h3>
                    <p class="text-muted-foreground">There is no data available to edit at the moment.</p>
                </div>
            </div>
        }
    </div>
</div>

<script>
    // Soft highlight for the recently edited user
    (function () {
        const editedUserId = '@(editedUserId ?? string.Empty)';
        if (!editedUserId) return;

        const row = document.querySelector(`tr[data-user-id="${editedUserId}"]`);
        if (!row) return;

        row.classList.add('user-row-pulse');
        row.scrollIntoView({ behavior: 'smooth', block: 'center' });

        setTimeout(() => {
            row.classList.remove('user-row-pulse');
        }, 8000);
    })();
</script>
