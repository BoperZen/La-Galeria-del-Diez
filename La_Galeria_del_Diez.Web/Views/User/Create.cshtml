@model La_Galeria_del_Diez.Application.DTOs.UserDTO

@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4 max-w-6xl">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center space-x-4">
                <a asp-action="Index" class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-muted hover:bg-muted/80 transition-colors">
                    <i class="bi bi-arrow-left text-xl"></i>
                </a>
                <div>
                    <h1 class="text-4xl font-bold text-foreground">Crear Usuario</h1>
                    <p class="text-muted-foreground">Completa la información del nuevo usuario</p>
                </div>
            </div>
            <div class="flex gap-3">
                <button type="button"
                        class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                    <i class="bi bi-check2-circle mr-2"></i>
                    Guardar
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Profile Card -->
            <div class="lg:col-span-1">
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden sticky top-24">
                    <!-- Profile Header -->
                    <div class="bg-gradient-to-br from-primary/20 to-accent/20 p-8 text-center border-b border-border">
                        <div class="w-32 h-32 bg-primary/30 rounded-full flex items-center justify-center mx-auto mb-4 border-4 border-primary">
                            <span class="text-6xl font-bold text-primary">U</span>
                        </div>
                        <h2 class="text-2xl font-bold text-foreground mb-2">Nuevo Usuario</h2>
                        <p class="text-muted-foreground text-sm mb-4">correo@ejemplo.com</p>

                        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-muted text-foreground border border-border">
                            <span class="w-2 h-2 bg-muted-foreground rounded-full mr-2"></span>
                            Estado pendiente
                        </span>
                    </div>

                    <!-- Quick Stats -->
                    <div class="p-6 space-y-4">
                        <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                                    <i class="bi bi-shield-check text-primary"></i>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Rol</p>
                                    <p class="font-semibold text-foreground">Por definir</p>
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center">
                                    <i class="bi bi-calendar text-accent"></i>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Fecha de alta</p>
                                    <p class="font-semibold text-foreground">@DateTime.Now.ToString("dd MMM yyyy")</p>
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                                    <i class="bi bi-hash text-primary"></i>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">ID de Usuario</p>
                                    <p class="font-semibold text-foreground font-mono">(autogenerado)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details Card -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Information Section -->
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden">
                    <div class="bg-muted px-6 py-4 border-b border-border">
                        <h3 class="text-lg font-bold text-foreground flex items-center">
                            <i class="bi bi-info-circle mr-2"></i>
                            Información Personal
                        </h3>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-person mr-2"></i>
                                    Nombre de Usuario
                                </label>
                                <input type="text" placeholder="Ingrese el nombre de usuario"
                                       class="w-full text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                            </div>

                            <div>
                                <label class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-envelope mr-2"></i>
                                    Email
                                </label>
                                <input type="email" placeholder="usuario@correo.com"
                                       class="w-full text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                            </div>

                            <div>
                                <label class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-shield-lock mr-2"></i>
                                    Contraseña
                                </label>
                                <input type="password" placeholder="••••••••"
                                       class="w-full text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                            </div>

                            <div>
                                <label class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-calendar-event mr-2"></i>
                                    Fecha de Registro
                                </label>
                                <input type="datetime-local"
                                       class="w-full text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Account Details -->
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden">
                    <div class="bg-muted px-6 py-4 border-b border-border">
                        <h3 class="text-lg font-bold text-foreground flex items-center">
                            <i class="bi bi-gear mr-2"></i>
                            Configuración de Cuenta
                        </h3>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-shield-check mr-2"></i>
                                    Rol Asignado
                                </label>
                                <select class="w-full text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-ring">
                                    <option value="">Seleccione un rol</option>
                                    <option>Administrador</option>
                                    <option>Vendedor</option>
                                    <option>Comprador</option>
                                </select>
                            </div>

                            <div>
                                <label class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-toggle-on mr-2"></i>
                                    Estado de la Cuenta
                                </label>
                                <select class="w-full text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-ring">
                                    <option>Activa</option>
                                    <option>Inactiva</option>
                                </select>
                            </div>

                            <div>
                                <label class="text-sm font-medium text-muted-foreground mb-2 flex items-center">
                                    <i class="bi bi-stopwatch mr-2"></i>
                                    Tally
                                </label>
                                <input type="number" placeholder="0"
                                       class="w-full text-base font-semibold text-foreground bg-muted/30 px-4 py-3 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Activity Timeline -->
                <div class="bg-card rounded-xl shadow-2xl border border-border overflow-hidden">
                    <div class="bg-muted px-6 py-4 border-b border-border">
                        <h3 class="text-lg font-bold text-foreground flex items-center">
                            <i class="bi bi-clock-history mr-2"></i>
                            Vista previa
                        </h3>
                    </div>
                    <div class="p-6">
                        <div class="text-center py-8 text-muted-foreground">
                            <i class="bi bi-info-circle text-4xl mb-3"></i>
                            <p>Formulario visual de creación (sin funcionalidad backend)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-8 flex justify-between items-center">
            <a asp-action="Index" 
               class="inline-flex items-center px-6 py-3 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                <i class="bi bi-arrow-left mr-2"></i>
                Volver a la Lista
            </a>
            <div class="flex gap-3">
                <button type="button"
                        class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                    <i class="bi bi-check2-circle mr-2"></i>
                    Guardar Usuario
                </button>
            </div>
        </div>
    </div>
</div>
