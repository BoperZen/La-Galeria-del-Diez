@model La_Galeria_del_Diez.Application.DTOs.UserDTO

@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4 max-w-3xl">
        <form asp-action="Create" method="post" class="bg-card rounded-xl shadow-2xl border border-border p-6 space-y-6">
            @Html.AntiForgeryToken()

            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-foreground">Crear usuario</h1>
                    <p class="text-muted-foreground">Registra un nuevo usuario en la plataforma.</p>
                </div>
                <a asp-action="Index" class="inline-flex items-center px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-colors font-semibold">
                    <i class="bi bi-arrow-left mr-2"></i>
                    Volver
                </a>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-400"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="Username" class="block text-sm font-medium text-foreground mb-2"></label>
                    <input asp-for="Username" class="w-full px-4 py-2 bg-muted border border-border rounded-md text-foreground" />
                    <span asp-validation-for="Username" class="text-red-400 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-foreground mb-2"></label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-2 bg-muted border border-border rounded-md text-foreground" />
                    <span asp-validation-for="Email" class="text-red-400 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-foreground mb-2"></label>
                    <input asp-for="Password" type="password" class="w-full px-4 py-2 bg-muted border border-border rounded-md text-foreground" />
                    <span asp-validation-for="Password" class="text-red-400 text-xs"></span>
                </div>

                <div>
                    <label asp-for="IdRol" class="block text-sm font-medium text-foreground mb-2">Rol</label>
                    <select asp-for="IdRol" class="w-full px-4 py-2 bg-muted border border-border rounded-md text-foreground">
                        <option value="1">Administrador</option>
                        <option value="2">Vendedor</option>
                        <option value="3">Comprador</option>
                    </select>
                    <span asp-validation-for="IdRol" class="text-red-400 text-xs"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="UserState" class="block text-sm font-medium text-foreground mb-2">Estado</label>
                    <select asp-for="UserState" class="w-full px-4 py-2 bg-muted border border-border rounded-md text-foreground">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                    <span asp-validation-for="UserState" class="text-red-400 text-xs"></span>
                </div>
            </div>

            <div class="flex justify-end">
                <button type="submit" class="inline-flex items-center px-6 py-2.5 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-colors font-semibold">
                    <i class="bi bi-check2-circle mr-2"></i>
                    Guardar usuario
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
