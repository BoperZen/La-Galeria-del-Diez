@model La_Galeria_del_Diez.Application.DTOs.AuctionDTO

@{
    ViewData["Title"] = "Crear Subasta";
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4 max-w-6xl">
        <!-- Breadcrumb -->
        <div class="mb-4">
            <a asp-controller="Subasta" asp-action="Index"
               class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">
                <i class="bi bi-arrow-left mr-2"></i>
                Volver a Subastas
            </a>
        </div>

        <!-- Título -->
        <h1 class="text-xl font-bold text-foreground mb-4">Crear Subasta</h1>

        <form asp-action="Create" method="post" class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
            <!-- IZQUIERDA: Objeto seleccionado (preview visual) -->
            <div class="lg:col-span-1">
                <div class="bg-card rounded-lg border border-border overflow-hidden mb-2">
                    <div class="bg-muted w-full h-48 flex items-center justify-center flex-col gap-2 text-muted-foreground">
                        <img id="imagePreview" class="hidden max-h-full max-w-full object-contain" alt="Vista previa" />
                        <span id="imagePreviewPlaceholder" class="text-xs">Vista previa del objeto</span>
                    </div>
                </div>

                <div class="bg-card rounded-lg border border-border p-3">
                    <div class="text-xs text-muted-foreground mb-1">Objeto seleccionado</div>
                    <div id="selectedObjectName" class="font-semibold text-foreground text-sm">Nombre del objeto (placeholder)</div>
                </div>
            </div>

            <!-- DERECHA: Datos de la subasta -->
            <div class="lg:col-span-2 flex flex-col gap-4">
                <div class="bg-card rounded-lg border border-border p-4">
                    <div asp-validation-summary="ModelOnly" class="text-xs text-red-500 mb-3"></div>
                    <h2 class="text-sm font-bold text-foreground mb-3 flex items-center">
                        <i class="bi bi-gavel mr-2 text-primary text-xs"></i>
                        Datos de la Subasta
                    </h2>

                    <!-- Selector de objeto (desplegable con recuadros) -->
                    <div class="py-2 border-b border-border">
                        <label asp-for="IdObject" class="text-xs text-muted-foreground mb-2 block"></label>
                        <details class="group bg-muted/30 rounded border border-border">
                            <summary class="list-none cursor-pointer px-3 py-2 flex items-center justify-between text-sm text-foreground">
                                <span>Seleccionar objeto</span>
                                <i class="bi bi-chevron-down text-xs transition-transform group-open:rotate-180"></i>
                            </summary>
                            <div class="p-3 border-t border-border">
                                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                                    @foreach (var item in (IEnumerable<dynamic>)ViewBag.ListObject){
                                        <button type="button"
                                                class="object-select p-2 rounded border border-border bg-card hover:border-primary text-left transition-colors"
                                                data-id="@item.Id"
                                                data-image="data:image/jpeg;base64,@Convert.ToBase64String(@item.Images[0].Data)"
                                                data-name="@item.Name">
                                            <div class="h-14 bg-muted/50 rounded mb-2 flex items-center justify-center overflow-hidden">
                                                <img id="mainImageSrc"
                                                     class="max-h-full max-w-full object-contain"
                                                     src="data:image/jpeg;base64,@Convert.ToBase64String(@item.Images[0].Data)"
                                                     alt="Shirt @item.Name"
                                                     loading="lazy" />
                                            </div>
                                            <div class="text-xs text-foreground font-medium truncate">@item.Name</div>
                                        </button>
                                    }
                                </div>
                            </div>
                        </details>
                        <select asp-for="IdObject" class="hidden">
                            <option value="">Seleccionar objeto</option>
                            @foreach (var item in (IEnumerable<dynamic>)ViewBag.ListObject)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                        <span asp-validation-for="IdObject" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Fecha Inicio -->
                    <div class="py-2 border-b border-border">
                        <label asp-for="StartDate" class="text-xs text-muted-foreground mb-1 block"></label>
                        <input asp-for="StartDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local"
                               class="w-full text-sm font-semibold text-foreground bg-muted/30 px-3 py-2 rounded border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                        <span asp-validation-for="StartDate" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Fecha Cierre -->
                    <div class="py-2 border-b border-border">
                        <label asp-for="EndDate" class="text-xs text-muted-foreground mb-1 block"></label>
                        <input asp-for="EndDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local"
                               class="w-full text-sm font-semibold text-foreground bg-muted/30 px-3 py-2 rounded border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                        <span asp-validation-for="EndDate" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Precio Base -->
                    <div class="py-2 border-b border-border">
                        <label asp-for="BasePrice" class="text-xs text-muted-foreground mb-1 block"></label>
                        <input asp-for="BasePrice" type="number" placeholder="0"
                               class="w-full text-sm font-semibold text-foreground bg-muted/30 px-3 py-2 rounded border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                        <span asp-validation-for="BasePrice" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Incremento Mínimo -->
                    <div class="py-2 border-b border-border">
                        <label asp-for="MinIncrement" class="text-xs text-muted-foreground mb-1 block"></label>
                        <input asp-for="MinIncrement" type="number" placeholder="0"
                               class="w-full text-sm font-semibold text-foreground bg-muted/30 px-3 py-2 rounded border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                        <span asp-validation-for="MinIncrement" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Estado inicial visual -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-check-circle-fill text-foreground text-xs"></i>
                        </div>
                        <!-- Siempre estado activo -->
                        <input type="hidden" asp-for="IdState" value="1">
                        <div class="flex-1">
                            <div class="text-xs text-muted-foreground">Estado inicial</div>
                            <div class="font-semibold text-foreground text-sm">Activa (no editable)</div>
                        </div>
                    </div>

                    <!-- Usuario visual -->
                    <div class="flex items-center gap-3 py-2">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-person-fill text-foreground text-xs"></i>
                        </div>
                        <!-- User input -->
                        <input type="hidden" asp-for="IdUser" value="@ViewBag.User.Id">
                        <div class="flex-1">
                            <div class="text-xs text-muted-foreground">Usuario</div>
                            <div class="font-semibold text-foreground text-sm">@ViewBag.User.Username</div>
                        </div>
                    </div>
                </div>

                <!-- Botones visuales -->
                <div class="flex justify-end gap-3">
                    <a asp-action="Index"
                       class="inline-flex items-center px-5 py-2.5 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                        <i class="bi bi-x-circle mr-2"></i>
                        Cancelar
                    </a>
                    <button type="submit"
                            class="inline-flex items-center px-5 py-2.5 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                        <i class="bi bi-check2-circle mr-2"></i>
                        Guardar Subasta
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const preview = document.getElementById('imagePreview');
        const placeholder = document.getElementById('imagePreviewPlaceholder');
        const objectSelect = document.getElementById('IdObject');
        const selectedObjectName = document.getElementById('selectedObjectName');
        const startDateInput = document.getElementById('StartDate');
        const endDateInput = document.getElementById('EndDate');

        const toLocalDateTimeValue = (date) => {
            const pad = (value) => value.toString().padStart(2, '0');
            return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
        };

        const nowValue = toLocalDateTimeValue(new Date());
        const isDefaultDate = (value) => !value || value.startsWith('0001-');
        if (startDateInput && isDefaultDate(startDateInput.value)) {
            startDateInput.value = nowValue;
        }
        if (endDateInput && isDefaultDate(endDateInput.value)) {
            endDateInput.value = nowValue;
        }

        document.querySelectorAll('.object-select').forEach((button) => {
            button.addEventListener('click', () => {
                const image = button.getAttribute('data-image');
                const name = button.getAttribute('data-name');
                const id = button.getAttribute('data-id');

                if (!image || !preview) {
                    return;
                }

                preview.src = image;
                preview.alt = name || 'Vista previa';
                preview.classList.remove('hidden');
                placeholder?.classList.add('hidden');
                if (objectSelect && id) {
                    objectSelect.value = id;
                }
                if (selectedObjectName) {
                    selectedObjectName.textContent = name || 'Nombre del objeto (placeholder)';
                }
            });
        });
    </script>
}
