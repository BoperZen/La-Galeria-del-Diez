@model La_Galeria_del_Diez.Application.DTOs.AuctionDTO

@{
ViewData["Title"] = "Detalles de la Subasta";
var auctionObject = Model.Object;
    
var isActive = Model.EndDate > DateTime.Now;
    var timeRemaining = Model.EndDate - DateTime.Now;
    var totalBids = Model.Biddings?.Count ?? 0;
    var currentPrice = Model.Biddings?.Any() == true 
        ? Model.Biddings.Max(b => b.Amount) 
        : Model.BasePrice;
    var currentUserId = ViewBag.CurrentUserId is int id ? id : 0;
    var canBid = isActive && currentUserId > 0 && currentUserId != Model.IdUser;
    var nextBidAmount = currentPrice + Model.MinIncrement;
}

<style>
    .bid-card {
        border-radius: 14px;
    }

    .bid-control {
        min-width: 36px;
        min-height: 36px;
        border-radius: 9999px;
        background-color: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }

    .bid-control:hover:not(:disabled) {
        background-color: rgba(255, 255, 255, 0.06);
    }

    .bid-control:active:not(:disabled) {
        transform: scale(0.95);
    }

    .bid-control:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .bid-amount {
        min-width: 140px;
        flex: 1;
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        border-radius: 10px;
    }

    .bid-controls {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
    }

    .bid-meta {
        font-size: 0.85rem;
    }

    .bid-title {
        font-size: 0.95rem;
        font-weight: 600;
    }

    .bid-meta + .bid-meta {
        margin-top: 0.5rem;
    }

    .bid-submit {
        padding: 12px 32px;
        border-radius: 8px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: filter 0.2s ease;
    }

    .bid-submit:hover:not(:disabled) {
        filter: brightness(1.08);
    }

    .bid-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .details-scope .text-xl,
    .details-scope .text-lg,
    .details-scope .text-base {
        font-size: 0.95rem;
    }

    .details-scope .text-sm,
    .details-scope .text-xs {
        font-size: 0.85rem;
    }
</style>

<div class="min-h-screen bg-background py-8 details-scope">
    <div class="container mx-auto px-4 max-w-6xl">
        <!-- Breadcrumb -->
        <div class="mb-4">
            <a asp-controller="Subasta" asp-action="Index" 
               class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">
                <i class="bi bi-arrow-left mr-2"></i>
                Volver a Subastas
            </a>
        </div>

        <!-- Título y Estado -->
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
            <h1 class="text-xl font-bold text-foreground">Detalles de la Subasta</h1>
            
            @if (isActive)
            {
                <div class="flex items-center gap-2">
                    <span class="bg-green-500 text-white px-3 py-1 rounded-full text-xs font-bold">
                        ACTIVA
                    </span>
                    @if (timeRemaining.TotalHours < 24)
                    {
                        <span class="bg-red-500 text-white px-2 py-1 rounded-full text-xs font-bold">
                            <i class="bi bi-exclamation-triangle mr-1"></i>
                            ˇQuedan @((int)timeRemaining.TotalHours)h @timeRemaining.Minutes m!
                        </span>
                    }
                </div>
            }
            else
            {
                <span class="bg-gray-400 text-white px-3 py-1 rounded-full text-xs font-bold">
                    FINALIZADA
                </span>
            }
        </div>

        <!-- BLOQUE SUPERIOR: Imagen (izq) + Info (der) -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
            
            <!-- IZQUIERDA: Imagen del objeto (1 de 3 columnas) -->
            <div class="lg:col-span-1">
                <!-- Imagen principal -->
                <div class="bg-card rounded-lg border border-border overflow-hidden mb-2">
                    @if (auctionObject.Images.Any())
                    {
                        <div class="bg-muted w-full h-48">
                            <img src="@Url.Action("GetImage", "Image", new { objectId = auctionObject.Id })" 
                                 alt="@auctionObject.Name" 
                                 class="w-full h-full object-contain">
                        </div>
                    }
                    else
                    {
                        <div class="bg-muted w-full h-48 flex items-center justify-center">
                            <i class="bi bi-image text-3xl text-muted-foreground"></i>
                        </div>
                    }
                </div>

                <!-- Botón Ver Detalle del Objeto -->
                <a asp-controller="Object" asp-action="Details" asp-route-id="@auctionObject.Id"
                   class="w-full inline-flex items-center justify-center px-4 py-3 bg-card text-foreground border-2 border-border rounded-lg hover:border-primary hover:bg-primary/5 transition-all font-semibold">
                    <i class="bi bi-box-seam mr-2"></i>
                    Ver Detalle del Objeto
                </a>

                <details class="w-full mt-3 bid-card border border-border bg-card">
                    <summary class="list-none cursor-pointer px-4 py-3 flex items-center justify-between bid-title text-foreground">
                        <span class="flex items-center">
                            <i class="bi bi-cash-coin mr-2 text-primary"></i>
                            Pujar por este objeto
                        </span>
                        <i class="bi bi-chevron-down text-xs transition-transform"></i>
                    </summary>
                    <div class="px-4 pb-4 pt-2 space-y-4">
                        <div class="rounded-lg border border-border p-4 space-y-4" style="background-color: rgba(255,255,255,0.02);">
                            <div class="bid-meta text-muted-foreground">
                                Última puja registrada
                            </div>
                            <div class="bid-controls">
                                <button type="button"
                                        class="bid-control border border-border text-foreground"
                                        data-bid-action="decrease"
                                        @(canBid ? "" : "disabled")>
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input type="text"
                                       id="bidAmountInput"
                                       value="@nextBidAmount.ToString("N0")"
                                       data-step="@Model.MinIncrement"
                                       data-min="@nextBidAmount"
                                       class="bid-amount text-center px-4 py-2 bg-muted border border-border text-foreground"
                                       readonly>
                                <button type="button"
                                        class="bid-control border border-border text-foreground"
                                        data-bid-action="increase"
                                        @(canBid ? "" : "disabled")>
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                            <div class="flex justify-between">
                                <div>
                                    <div class="bid-meta text-muted-foreground">Precio actual</div>
                                    <div class="font-semibold text-foreground">$@currentPrice.ToString("N0")</div>
                                </div>
                                <div>
                                    <div class="bid-meta text-muted-foreground">Incremento mínimo</div>
                                    <div class="font-semibold text-foreground">$@Model.MinIncrement.ToString("N0")</div>
                                </div>
                            </div>
                            @if (!isActive)
                            {
                                <div class="bid-meta text-red-400">La subasta no está activa.</div>
                            }
                            @if (currentUserId == Model.IdUser)
                            {
                                <div class="bid-meta text-red-400">El vendedor no puede pujar en su propia subasta.</div>
                            }
                        </div>

                        <div class="flex justify-end">
                            <button type="button"
                                    class="bid-submit bg-primary text-primary-foreground hover:bg-secondary shadow-lg @(canBid ? "" : "")"
                                    @(canBid ? "" : "disabled")>
                                <i class="bi bi-arrow-right-circle"></i>
                                Pujar
                            </button>
                        </div>
                    </div>
                </details>
            </div>

            <!-- DERECHA: Información de la Subasta (2 de 3 columnas) -->
            <div class="lg:col-span-2 flex flex-col gap-4 h-full">
                <!-- Bloque de datos de la subasta -->
                <div class="bg-card rounded-lg border border-border p-4">
                    <h2 class="text-sm font-bold text-foreground mb-3 flex items-center">
                        <i class="bi bi-gavel mr-2 text-primary text-xs"></i>
                        Datos de la Subasta
                    </h2>
                    
                    <!-- Fecha Inicio -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-calendar-check text-muted-foreground text-xs"></i>
                        </div>

<script>
    document.querySelectorAll('[data-bid-action]')?.forEach((button) => {
        button.addEventListener('click', () => {
            const input = document.getElementById('bidAmountInput');
            if (!input) {
                return;
            }

            const step = Number(input.dataset.step || '0');
            const min = Number(input.dataset.min || '0');
            const raw = input.value.replace(/,/g, '');
            const current = Number(raw || '0');
            const action = button.getAttribute('data-bid-action');
            let next = current;

            if (action === 'increase') {
                next = current + step;
            }

            if (action === 'decrease') {
                next = Math.max(min, current - step);
            }

            input.value = next.toLocaleString('en-US');
        });
    });
</script>
                        <div>
                            <div class="text-xs text-muted-foreground">Fecha de Inicio</div>
                            <div class="font-semibold text-foreground text-sm">
                                @Model.StartDate.ToString("dd/MM/yyyy") - @Model.StartDate.ToString("HH:mm")
                            </div>
                        </div>
                    </div>

                    <!-- Fecha Cierre -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-calendar-x text-muted-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Fecha de Cierre</div>
                            <div class="font-semibold text-foreground text-sm">
                                @Model.EndDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("HH:mm")
                            </div>
                        </div>
                    </div>

                    <!-- Precio Base -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-tag text-muted-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Precio Base</div>
                            <div class="font-bold text-foreground text-base">$@Model.BasePrice.ToString("N0")</div>
                        </div>
                    </div>

                    <!-- Incremento Mínimo -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-arrow-up-circle text-muted-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Incremento Mínimo</div>
                            <div class="font-bold text-foreground text-base">$@Model.MinIncrement.ToString("N0")</div>
                        </div>
                    </div>

                    <!-- Estado Actual -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-info-circle text-muted-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Estado</div>
                            <div class="font-semibold text-foreground text-sm">@Model.State.Description</div>
                        </div>
                    </div>

                    <!-- Cantidad de Pujas -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-hand-index text-muted-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Total de Pujas</div>
                            <div class="font-bold text-foreground text-base">@totalBids</div>
                        </div>
                    </div>

                    <!-- Precio Actual -->
                    <div class="flex items-center gap-3 py-2">
                        <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-currency-dollar text-muted-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Precio Actual</div>
                            <div class="font-bold text-primary text-xl">$@currentPrice.ToString("N0")</div>
                        </div>
                    </div>
                </div>

                <!-- Historial de Pujas -->
                <div class="bg-card rounded-lg border border-border overflow-hidden">
                    <div class="bg-muted/30 px-4 py-2.5 border-b border-border">
                        <h2 class="text-sm font-bold text-foreground flex items-center justify-between">
                            <span class="flex items-center">
                                <i class="bi bi-list-ol mr-2 text-primary text-xs"></i>
                                Historial de Pujas
                            </span>
                            <span class="bg-primary text-primary-foreground px-2 py-0.5 rounded-full text-xs">
                                @totalBids
                            </span>
                        </h2>
                    </div>

                    @if (Model.Biddings != null && Model.Biddings.Any())
                    {
                        <div class="divide-y divide-border max-h-80 overflow-y-auto">
                            @foreach (var bidding in Model.Biddings.OrderByDescending(b => b.RegistrationDate))
                            {
                                var isHighestBid = bidding.Amount == currentPrice;
                                
                                <div class="p-3 hover:bg-muted/10 transition-colors @(isHighestBid ? "bg-primary/5" : "")">
                                    <div class="flex items-center justify-between gap-3">
                                        <!-- Usuario -->
                                        <div class="flex items-center gap-2 flex-1">
                                            <div class="w-7 h-7 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                                <i class="bi bi-person-fill text-primary text-xs"></i>
                                            </div>
                                            <div class="min-w-0">
                                                <div class="font-semibold text-foreground text-sm truncate">Usuario #@bidding.IdUser</div>
                                                <div class="text-xs text-muted-foreground">@bidding.PaymentMethod</div>
                                            </div>
                                        </div>

                                        <!-- Monto -->
                                        @if (isHighestBid)
                                        {
                                            <div class="text-xs bg-primary text-primary-foreground p-1 rounded-full font-semibold">
                                                Más alta
                                            </div>
                                        }
                                        <div class="text-right">
                                            <div class="font-bold text-primary text-base">
                                                $@bidding.Amount.ToString("N0")
                                            </div>
                                        </div>

                                        <!-- Fecha y Hora -->
                                        <div class="text-right">
                                            <div class="font-semibold text-foreground text-xs">@bidding.RegistrationDate.ToString("dd/MM/yyyy")</div>
                                            <div class="text-xs text-muted-foreground">@bidding.RegistrationDate.ToString("HH:mm:ss")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-8 text-center">
                            <i class="bi bi-inbox text-4xl text-muted-foreground mb-3 block"></i>
                            <p class="text-muted-foreground">No hay pujas registradas aún</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
