@model X.PagedList.IPagedList<La_Galeria_del_Diez.Application.DTOs.AuctionDTO>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Active Auctions";
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4">
        <!-- Header with filters -->
        <div class="mb-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
                <div>
                    <h1 class="text-4xl font-bold text-foreground mb-2 flex items-center">
                        <i class="bi bi-hammer text-primary mr-3"></i>
                        Active Auctions
                    </h1>
                    <p class="text-muted-foreground">Place your bid before time runs out.</p>
                    @if (ViewBag.Debug != null)
                    {
                        <p class="text-yellow-400 text-sm mt-2">DEBUG: @ViewBag.Debug</p>
                    }
                </div>
                <div class="flex flex-col sm:flex-row gap-3">
                    <a asp-action="Create"
                       class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                        <i class="bi bi-plus-circle mr-2"></i>
                        Create Auction
                    </a>
                    <a asp-action="Borrador"
                       class="inline-flex items-center px-6 py-3 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                        <i class="bi bi-file-earmark-text mr-2"></i>
                        View Drafts
                    </a>
                    <a asp-action="Finalizadas"
                       class="inline-flex items-center px-6 py-3 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                        <i class="bi bi-clock-history mr-2"></i>
                        View Finished
                    </a>
                </div>
            </div>

            <!-- Filters and search -->
            <div class="bg-card rounded-xl shadow-lg p-6 border border-border">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div class="md:col-span-2">
                        <input type="text"
                               id="searchInput"
                               placeholder="Search by item name..."
                               class="w-full px-4 py-2.5 pl-10 bg-muted border border-border rounded-lg text-foreground placeholder-placeholder focus:outline-none focus:ring-2 focus:ring-ring">
                        <i class="bi bi-search absolute left-3 top-3 text-muted-foreground"></i>
                    </div>
                    <select class="px-4 py-2.5 bg-muted border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-ring">
                        <option>Sort by: Most recent</option>
                        <option>Price: Low to High</option>
                        <option>Price: High to Low</option>
                        <option>Ended recently</option>
                    </select>
                    <select class="px-4 py-2.5 bg-muted border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-ring">
                        <option>All categories</option>
                        <option>Shirts</option>
                        <option>Balls</option>
                        <option>Medals</option>
                    </select>
                </div>
            </div>
        </div>

        @if (Model.Any())
        {
            <!-- Finished Auctions Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="auctionsGrid">
                @foreach (var auction in Model)
                {
                    var obj = auction.Object;
                    var bidCount = auction.Biddings?.Count ?? 0;
                    var finalPrice = auction.Biddings?.Any() == true
                    ? auction.Biddings.Max(b => b.Amount)
                    : auction.BasePrice;
                    var isCanceled = auction.State.Description == "Cancelada";

                    <div class="group bg-card rounded-xl shadow-lg border border-border overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105 auction-card">
                        <!-- Image -->
                        <div class="relative h-64 overflow-hidden bg-muted">
                            @if (obj.Images.Any())
                            {
                                <img src="@Url.Action("GetImage", "Image", new { objectId = obj.Id })"
                                     alt="@obj.Name"
                                     class="w-full h-full object-cover @(isCanceled ? "opacity-50 grayscale" : "")"
                                     loading="lazy">
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <i class="bi bi-image text-5xl text-muted-foreground"></i>
                                </div>
                            }

                            <!-- Badge de estado -->
                            <div class="absolute top-3 right-3">
                                @if (isCanceled)
                                {
                                    <span class="px-4 py-2 bg-red-500/90 text-white text-sm font-bold rounded-full shadow-lg backdrop-blur-sm">
                                        <i class="bi bi-x-circle mr-1"></i>
                                        Cancelada
                                    </span>
                                }
                                else
                                {
                                    <span class="px-4 py-2 bg-green-500/90 text-white text-sm font-bold rounded-full shadow-lg backdrop-blur-sm">
                                        <i class="bi bi-check-circle mr-1"></i>
                                        Finalizada
                                    </span>
                                }
                            </div>

                            <!-- Número de pujas -->
                            <div class="absolute top-3 left-3">
                                <span class="px-3 py-1.5 bg-black/60 text-white text-sm font-semibold rounded-full backdrop-blur-sm">
                                    <i class="bi bi-people-fill mr-1"></i>
                                    @bidCount puja@(bidCount != 1 ? "s" : "")
                                </span>
                            </div>
                        </div>

                        <!-- Contenido -->
                        <div class="p-6">
                            <!-- Nombre -->
                            <h3 class="font-bold text-foreground text-xl mb-3 line-clamp-2">
                                @obj.Name
                            </h3>

                            <!-- Info Grid -->
                            <div class="grid grid-cols-2 gap-4 mb-4">
                                <!-- Fecha de cierre -->
                                <div class="bg-muted/30 rounded-lg p-3">
                                    <p class="text-xs text-muted-foreground mb-1 flex items-center">
                                        <i class="bi bi-calendar-check mr-1"></i>
                                        Finalizada
                                    </p>
                                    <p class="text-sm font-semibold text-foreground">
                                        @auction.EndDate.ToString("dd/MM/yyyy")
                                    </p>
                                </div>

                                <!-- Precio final -->
                                <div class="bg-muted/30 rounded-lg p-3">
                                    <p class="text-xs text-muted-foreground mb-1 flex items-center">
                                        <i class="bi bi-currency-dollar mr-1"></i>
                                        Precio Final
                                    </p>
                                    <p class="text-sm font-bold text-primary">
                                        $@finalPrice.ToString("N0")
                                    </p>
                                </div>
                            </div>

                            <!-- Ganador (si hay) -->
                            @if (!isCanceled && auction.Winner != null)
                            {
                                <div class="bg-primary/10 border border-primary/30 rounded-lg p-3 mb-4">
                                    <p class="text-xs text-primary font-semibold mb-1 flex items-center">
                                        <i class="bi bi-trophy-fill mr-2"></i>
                                        Ganador
                                    </p>
                                    <p class="text-sm font-bold text-foreground">
                                        @auction.Winner.Username
                                    </p>
                                </div>
                            }

                            <!-- Botones de acción -->
                            <div class="flex gap-2">
                                <a asp-controller="Subasta" asp-action="Details" asp-route-id="@auction.Id"
                                   class="flex-1 inline-flex items-center justify-center px-4 py-2.5 bg-primary text-primary-foreground rounded-lg hover:opacity-90 transition-all font-semibold">
                                    <i class="bi bi-eye mr-2"></i>
                                    Ver Detalle
                                </a>
                            </div>
                            @if(auction.StartDate > DateTime.Now && auction.Biddings.Count == 0)
                            {
                                <form asp-controller="Subasta" asp-action="Delete" asp-route-id="@auction.Id" method="post" class="flex-1 mt-2">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="w-full inline-flex items-center justify-center px-4 py-2.5 border border-red-500/40 text-red-400 rounded-lg hover:bg-red-500/10 hover:text-red-300 transition-all font-semibold">
                                        <i class="bi bi-trash mr-2"></i>
                                        Delete Auction
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="bg-card rounded-xl shadow-2xl border border-border p-16 text-center">
                <div class="max-w-md mx-auto">
                    <div class="w-24 h-24 bg-muted rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="bi bi-clock-history text-6xl text-muted-foreground"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-foreground mb-3">No hay subastas finalizadas</h3>
                    <p class="text-muted-foreground mb-6">
                        Todavía no se han completado subastas en el sistema.
                    </p>
                    <a asp-action="Finalizadas"
                       class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                        <i class="bi bi-hammer mr-2"></i>
                        View Finished Auctions
                    </a>
                </div>
            </div>
        }

        @if (Model.PageCount > 1)
        {
            <!-- Paginación -->
            <div class="flex justify-center mt-8">
                <div class="bg-card rounded-xl shadow-lg border border-border p-4">
                    @Html.PagedListPager(Model, page => Url.Action("Finalizadas", new { page }),
                    new PagedListRenderOptions
                    {
                        LiElementClasses = new string[] { "inline-block" },
                        PageClasses = new string[] { "px-4 py-2 mx-1 rounded-lg bg-muted text-foreground hover:bg-primary hover:text-primary-foreground transition-all" },
                        ActiveLiElementClass = "active",
                        UlElementClasses = new string[] { "flex items-center gap-2" }
                    })
            </div>
        </div>
                }
    </div>
</div>

<script>
    // Live search
    document.getElementById('searchInput')?.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const cards = document.querySelectorAll('.auction-card');

        cards.forEach(card => {
            const text = card.textContent.toLowerCase();
            card.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });
</script>
