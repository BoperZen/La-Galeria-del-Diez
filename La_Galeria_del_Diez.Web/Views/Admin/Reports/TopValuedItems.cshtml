@model IEnumerable<La_Galeria_del_Diez.Application.DTOs.Reports.TopValuedItemDto>
@{
    ViewData["Title"] = "Most valued items";
    var total = Model.Count();
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4">
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-foreground">Most valued items</h1>
            <p class="text-muted-foreground">Ranking of items by highest achieved price.</p>
            <span class="text-sm text-muted-foreground">Total records: @total</span>
            <div class="mt-3">
                <a href="/Admin/Reports"
                   class="inline-flex items-center px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                    <i class="bi bi-arrow-left mr-2"></i>
                    Back to reports
                </a>
            </div>
        </div>

        <div class="bg-card border border-border rounded-2xl shadow-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-muted/50 text-muted-foreground">
                        <tr class="text-left">
                            <th class="px-4 py-3">Rank</th>
                            <th class="px-4 py-3">Item</th>
                            <th class="px-4 py-3">Description</th>
                            <th class="px-4 py-3">Base price</th>
                            <th class="px-4 py-3">Max price</th>
                            <th class="px-4 py-3">Times auctioned</th>
                            <th class="px-4 py-3">Current status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 text-foreground">#@item.Rank</td>
                                <td class="px-4 py-3 text-foreground">@item.ItemName</td>
                                <td class="px-4 py-3 text-foreground">@item.Description</td>
                                <td class="px-4 py-3 text-foreground">$@item.BasePrice.ToString("N0")</td>
                                <td class="px-4 py-3 text-foreground">$@item.MaxPrice.ToString("N0")</td>
                                <td class="px-4 py-3 text-foreground">@item.AuctionCount</td>
                                <td class="px-4 py-3">
                                    <span class="px-2 py-1 rounded-full text-xs font-semibold @(item.CurrentStatus == "In auction" ? "bg-green-500/20 text-green-400" : "bg-muted text-foreground")">
                                        @item.CurrentStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
