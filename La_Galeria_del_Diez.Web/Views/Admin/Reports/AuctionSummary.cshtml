@model IEnumerable<La_Galeria_del_Diez.Application.DTOs.Reports.AuctionSummaryReportDto>
@{
    ViewData["Title"] = "Resumen de subastas";
    var total = Model.Count();
    var active = Model.Count(m => m.Status == "Activa");
    var finished = Model.Count(m => m.Status == "Finalizada");
    var canceled = Model.Count(m => m.Status == "Cancelada");
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4">
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-foreground">Resumen de subastas</h1>
            <p class="text-muted-foreground">Vista general de todas las subastas y sus métricas clave.</p>
            <span class="text-sm text-muted-foreground">Total registros: @total</span>
            <div class="mt-3">
                <a href="/Admin/Reports"
                   class="inline-flex items-center px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                    <i class="bi bi-arrow-left mr-2"></i>
                    Volver a reportes
                </a>
            </div>
        </div>

        <div class="bg-card border border-border rounded-2xl shadow-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-muted/50 text-muted-foreground">
                        <tr class="text-left">
                            <th class="px-4 py-3">Nombre/Título</th>
                            <th class="px-4 py-3">Objeto subastado</th>
                            <th class="px-4 py-3">Estado</th>
                            <th class="px-4 py-3">Precio base</th>
                            <th class="px-4 py-3">Precio actual</th>
                            <th class="px-4 py-3">Total pujas</th>
                            <th class="px-4 py-3">Fecha inicio</th>
                            <th class="px-4 py-3">Fecha fin</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        @foreach (var item in Model)
                        {
                            var badge = item.Status == "Activa" ? "bg-green-500/20 text-green-400" : item.Status == "Cancelada" ? "bg-red-500/20 text-red-400" : "bg-muted text-foreground";
                            <tr>
                                <td class="px-4 py-3 text-foreground">@item.AuctionTitle</td>
                                <td class="px-4 py-3 text-foreground">@item.ObjectName</td>
                                <td class="px-4 py-3"><span class="px-2 py-1 rounded-full text-xs font-semibold @badge">@item.Status</span></td>
                                <td class="px-4 py-3 text-foreground">$@item.BasePrice.ToString("N0")</td>
                                <td class="px-4 py-3 text-foreground">$@item.CurrentPrice.ToString("N0")</td>
                                <td class="px-4 py-3 text-foreground">@item.TotalBids</td>
                                <td class="px-4 py-3 text-foreground">@item.StartDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-3 text-foreground">@item.EndDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4 flex flex-wrap gap-3 text-sm">
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary font-semibold">Total: @total</span>
            <span class="px-3 py-1 rounded-full bg-green-500/20 text-green-400 font-semibold">Activas: @active</span>
            <span class="px-3 py-1 rounded-full bg-muted text-foreground font-semibold">Finalizadas: @finished</span>
            <span class="px-3 py-1 rounded-full bg-red-500/20 text-red-400 font-semibold">Canceladas: @canceled</span>
        </div>
    </div>
</div>
