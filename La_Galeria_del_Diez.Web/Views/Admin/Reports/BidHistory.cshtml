@model IEnumerable<La_Galeria_del_Diez.Application.DTOs.Reports.BidHistoryReportDto>
@{
    ViewData["Title"] = "Historial de pujas";
    var total = Model.Count();
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4">
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-foreground">Historial de pujas</h1>
            <p class="text-muted-foreground">Todas las pujas registradas en el sistema.</p>
            <span class="text-sm text-muted-foreground">Total registros: @total</span>
            <div class="mt-3">
                <a href="/Admin/Reports"
                   class="inline-flex items-center px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                    <i class="bi bi-arrow-left mr-2"></i>
                    Volver a reportes
                </a>
            </div>
        </div>

        <div class="bg-card border border-border rounded-2xl shadow-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-muted/50 text-muted-foreground">
                        <tr class="text-left">
                            <th class="px-4 py-3">Subasta</th>
                            <th class="px-4 py-3">Objeto</th>
                            <th class="px-4 py-3">Usuario</th>
                            <th class="px-4 py-3">Monto</th>
                            <th class="px-4 py-3">Fecha y hora</th>
                            <th class="px-4 py-3">Estado de la puja</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 text-foreground">@item.AuctionTitle</td>
                                <td class="px-4 py-3 text-foreground">@item.ObjectName</td>
                                <td class="px-4 py-3 text-foreground">@item.Bidder</td>
                                <td class="px-4 py-3 text-foreground">$@item.Amount.ToString("N0")</td>
                                <td class="px-4 py-3 text-foreground">@item.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td class="px-4 py-3">
                                    <span class="px-2 py-1 rounded-full text-xs font-semibold @(item.BidStatus == "Ganadora actual" ? "bg-green-500/20 text-green-400" : "bg-muted text-foreground")">
                                        @item.BidStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
