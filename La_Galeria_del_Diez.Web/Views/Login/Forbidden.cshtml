@{
    ViewData["Title"] = "Acceso denegado";
}

<div class="min-h-screen bg-background py-10">
    <div class="container mx-auto px-4 max-w-lg">
        <div class="bg-card border border-border rounded-xl shadow-lg p-6 text-center space-y-4">
            <i class="bi bi-shield-lock text-4xl text-yellow-400"></i>
            <h1 class="text-2xl font-bold text-foreground">Acceso denegado</h1>
            <p class="text-muted-foreground">No tienes permisos para acceder a este recurso.</p>
            <a asp-controller="Home" asp-action="Index" class="inline-flex items-center justify-center px-4 py-2 rounded-lg bg-primary text-primary-foreground font-semibold hover:bg-secondary transition-colors">
                Volver al inicio
            </a>
        </div>
    </div>
</div>
