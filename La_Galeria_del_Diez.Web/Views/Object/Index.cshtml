@model X.PagedList.IPagedList<La_Galeria_del_Diez.Application.DTOs.Auctionable_ObjectDTO>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Objetos Subastables";
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4">
        <!-- Header -->
        <div class="mb-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
                <div>
                    <h1 class="text-4xl font-bold text-foreground mb-2 flex items-center">
                        <i class="bi bi-box-seam text-primary mr-3"></i>
                        Objetos Subastables
                    </h1>
                    <p class="text-muted-foreground">Administra los objetos disponibles para subasta</p>
                </div>
                <a asp-action="Create" 
                   class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                    <i class="bi bi-plus-lg mr-2"></i>
                    Nuevo Objeto
                </a>
            </div>

            <!-- Filtros -->
            <div class="bg-card rounded-xl shadow-lg p-6 border border-border">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="md:col-span-2">
                        <input type="text" 
                               id="searchInput"
                               placeholder="Buscar por nombre..." 
                               class="w-full px-4 py-2.5 pl-10 bg-muted border border-border rounded-lg text-foreground placeholder-placeholder focus:outline-none focus:ring-2 focus:ring-ring">
                        <i class="bi bi-search absolute left-3 top-3 text-muted-foreground"></i>
                    </div>
                    <select class="px-4 py-2.5 bg-muted border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-ring">
                        <option>Todos los estados</option>
                        <option>En subasta</option>
                        <option>Disponible</option>
                        <option>Vendido</option>
                    </select>
                </div>
            </div>
        </div>

        @if (Model.Any())
        {
            <!-- Grid de Objetos -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-8" id="objectsGrid">
                @foreach (var obj in Model)
                {
                    var hasAuction = obj.Auctions.Any(a => a.EndDate > DateTime.Now);
                    var auction = obj.Auctions.FirstOrDefault(a => a.EndDate > DateTime.Now);

                    <div class="group bg-card rounded-xl shadow-lg border border-border overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105 object-card">
                        <!-- Imagen -->
                        <div class="relative h-56 overflow-hidden bg-muted">
                            @if (obj.Images.Any())
                            {
                                <img src="@Url.Action("GetImage", "Image", new { objectId = obj.Id })" 
                                     alt="@obj.Name" 
                                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                                     loading="lazy">
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <i class="bi bi-image text-6xl text-muted-foreground"></i>
                                </div>
                            }

                            <!-- Badge de estado -->
                            <div class="absolute top-3 right-3">
                                @if (hasAuction)
                                {
                                    <span class="px-3 py-1.5 bg-green-500/90 text-white text-xs font-bold rounded-full shadow-lg">
                                        <i class="bi bi-hammer mr-1"></i>
                                        En Subasta
                                    </span>
                                }
                                else
                                {
                                    <span class="px-3 py-1.5 bg-accent/90 text-white text-xs font-bold rounded-full shadow-lg">
                                        Disponible
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Contenido -->
                        <div class="p-5">
                            <!-- Categorías -->
                            @if (obj.Categories.Any())
                            {
                                <div class="flex flex-wrap gap-2 mb-3">
                                    @foreach (var cat in obj.Categories.Take(2))
                                    {
                                        <span class="px-2 py-1 bg-primary/10 text-primary text-xs rounded-md border border-primary/20">
                                            @cat.Description
                                        </span>
                                    }
                                </div>
                            }

                            <!-- Nombre -->
                            <h3 class="font-bold text-foreground text-lg mb-2 line-clamp-2 min-h-[3.5rem]">
                                @obj.Name
                            </h3>

                            <!-- Info Grid -->
                            <div class="grid grid-cols-2 gap-3 mb-4">
                                <div class="bg-muted/30 rounded-lg p-3">
                                    <p class="text-xs text-muted-foreground mb-1">Condición</p>
                                    <p class="text-sm font-semibold text-foreground">@(obj.Condition ?? "Nueva")</p>
                                </div>
                                <div class="bg-muted/30 rounded-lg p-3">
                                    <p class="text-xs text-muted-foreground mb-1">Estado</p>
                                    <p class="text-sm font-semibold text-foreground">@obj.State.Description</p>
                                </div>
                            </div>

                            @if (hasAuction && auction != null)
                            {
                                <div class="bg-primary/10 border border-primary/30 rounded-lg p-3 mb-4">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-xs text-primary mb-1">Precio Base</p>
                                            <p class="text-lg font-bold text-primary">$@auction.BasePrice.ToString("N0")</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-xs text-muted-foreground mb-1">Pujas</p>
                                            <p class="text-sm font-bold text-foreground">@auction.Biddings.Count</p>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Botones de acción -->
                            <div class="flex gap-2">
                                <a asp-action="Details" asp-route-id="@obj.Id"
                                   class="inline-flex items-center justify-center px-4 py-2.5 bg-accent text-accent-foreground rounded-lg hover:opacity-90 transition-all font-semibold text-sm"
                                   title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (hasAuction)
                                {
                                    <button type="button"
                                            disabled
                                            class="inline-flex items-center justify-center px-4 py-2.5 bg-primary/5 text-primary/40 border border-primary/10 rounded-lg cursor-not-allowed font-semibold text-sm"
                                            title="No se puede editar: objeto con subasta activa">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                }
                                else
                                {
                                    <a asp-action="Edit" asp-route-id="@obj.Id"
                                       class="inline-flex items-center justify-center px-4 py-2.5 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold text-sm"
                                       title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }

                                @if (hasAuction)
                                {
                                    <button type="button"
                                            disabled
                                            class="inline-flex items-center justify-center px-4 py-2.5 bg-red-500/5 text-red-300/60 border border-red-500/10 rounded-lg cursor-not-allowed font-semibold text-sm"
                                            title="No se puede eliminar: objeto con subasta activa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="delete-object-btn inline-flex items-center justify-center px-4 py-2.5 bg-red-500/10 text-red-400 border border-red-500/20 rounded-lg hover:bg-red-500/20 transition-all font-semibold text-sm"
                                            data-form-id="delete-form-@obj.Id"
                                            data-object-name="@obj.Name"
                                            title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>

                            <form id="delete-form-@obj.Id" asp-action="Delete" method="post" class="hidden">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@obj.Id" />
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- Paginación -->
            <div class="flex justify-center">
                <div class="bg-card rounded-xl shadow-lg border border-border p-4">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }),
                        new PagedListRenderOptions
                        {
                            LiElementClasses = new string[] { "inline-block" },
                            PageClasses = new string[] { "px-4 py-2 mx-1 rounded-lg bg-muted text-foreground hover:bg-primary hover:text-primary-foreground transition-all" },
                            ActiveLiElementClass = "active",
                            UlElementClasses = new string[] { "flex items-center gap-2" }
                        })
                </div>
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="bg-card rounded-xl shadow-2xl border border-border p-16 text-center">
                <div class="max-w-md mx-auto">
                    <div class="w-24 h-24 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="bi bi-box-seam text-6xl text-primary"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-foreground mb-3">No hay objetos registrados</h3>
                    <p class="text-muted-foreground mb-6">
                        Comienza agregando el primer objeto subastable al sistema
                    </p>
                    <a asp-action="Create" 
                       class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                        <i class="bi bi-plus-lg mr-2"></i>
                        Crear Primer Objeto
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div id="confirmDeleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4">
    <div class="w-full max-w-md rounded-xl border border-border bg-card shadow-2xl">
        <div class="px-6 py-4 border-b border-border">
            <h3 class="text-lg font-bold text-foreground flex items-center">
                <i class="bi bi-exclamation-triangle mr-2 text-red-400"></i>
                Confirmar eliminación
            </h3>
        </div>
        <div class="px-6 py-5 text-sm text-muted-foreground">
            ¿Desea eliminar el objeto <span id="deleteObjectName" class="font-semibold text-foreground"></span>?
        </div>
        <div class="px-6 py-4 border-t border-border flex justify-end gap-3">
            <button type="button" id="cancelDeleteBtn"
                    class="inline-flex items-center px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-colors font-semibold">
                Cancelar
            </button>
            <button type="button" id="confirmDeleteBtn"
                    class="inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-semibold">
                Eliminar
            </button>
        </div>
    </div>
</div>

<script>
    // Búsqueda en tiempo real
    document.getElementById('searchInput')?.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const cards = document.querySelectorAll('.object-card');
        
        cards.forEach(card => {
            const text = card.textContent.toLowerCase();
            card.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    // Confirmación visual de eliminación
    (function () {
        const modal = document.getElementById('confirmDeleteModal');
        const cancelBtn = document.getElementById('cancelDeleteBtn');
        const confirmBtn = document.getElementById('confirmDeleteBtn');
        const objectNameLabel = document.getElementById('deleteObjectName');
        const deleteButtons = document.querySelectorAll('.delete-object-btn');

        if (!modal || !cancelBtn || !confirmBtn || !objectNameLabel || deleteButtons.length === 0) return;

        let selectedFormId = null;

        deleteButtons.forEach(btn => {
            btn.addEventListener('click', function () {
                selectedFormId = this.getAttribute('data-form-id');
                const objectName = this.getAttribute('data-object-name') || 'seleccionado';
                objectNameLabel.textContent = `"${objectName}"`;
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });
        });

        cancelBtn.addEventListener('click', function () {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            selectedFormId = null;
        });

        confirmBtn.addEventListener('click', function () {
            if (!selectedFormId) return;
            const form = document.getElementById(selectedFormId);
            if (!form) return;
            form.submit();
        });

        modal.addEventListener('click', function (e) {
            if (e.target === modal) {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                selectedFormId = null;
            }
        });
    })();
</script>
