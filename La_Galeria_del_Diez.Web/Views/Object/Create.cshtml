@model La_Galeria_del_Diez.Application.DTOs.Auctionable_ObjectDTO

@{
    ViewData["Title"] = "Crear Objeto";
    var categories = ViewBag.Categories as IEnumerable<La_Galeria_del_Diez.Application.DTOs.CategoryDTO> ?? Enumerable.Empty<La_Galeria_del_Diez.Application.DTOs.CategoryDTO>();
    var selectedCategoryIds = ViewBag.SelectedCategoryIds as HashSet<int> ?? new HashSet<int>();
    var seller = ViewBag.Seller as La_Galeria_del_Diez.Application.DTOs.UserDTO;
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4 max-w-6xl">
        <form asp-action="Create" method="post" enctype="multipart/form-data" id="objectCreateForm">
            @Html.AntiForgeryToken()
            <input asp-for="IdState" type="hidden" />
            <input asp-for="IdUser" type="hidden" />
            <input asp-for="RegistrationDate" type="hidden" />

            <div class="mb-4">
                <a asp-controller="Object" asp-action="Index"
                   class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">
                    <i class="bi bi-arrow-left mr-2"></i>
                    Volver a Objetos
                </a>
            </div>

            <h1 class="text-xl font-bold text-foreground mb-4">Crear Objeto</h1>
            <div asp-validation-summary="ModelOnly" class="text-red-400 mb-4"></div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
                <div class="lg:col-span-1">
                    <div class="bg-card rounded-lg border border-border overflow-hidden mb-2">
                        <div class="bg-muted w-full h-48 flex items-center justify-center flex-col gap-2 text-muted-foreground">
                            <i class="bi bi-image text-3xl"></i>
                            <span class="text-xs">Vista previa de imagen principal</span>
                        </div>
                    </div>

                    <div class="bg-card rounded-lg border border-border p-3">
                        <label class="text-xs text-muted-foreground mb-2 block">Imágenes <span class="text-red-400">*</span></label>
                        <input type="file" name="imageFiles" multiple accept="image/*" required
                               class="w-full text-sm text-foreground bg-muted/30 border border-border rounded px-3 py-2 file:mr-3 file:px-3 file:py-1 file:rounded file:border-0 file:bg-primary file:text-primary-foreground" />
                        <p class="text-xs text-muted-foreground mt-2">Debe agregar al menos una imagen.</p>
                    </div>
                </div>

                <div class="lg:col-span-2 flex flex-col gap-4 h-full">
                    <div class="bg-card rounded-lg border border-border p-4">
                        <div class="py-2 border-b border-border">
                            <label asp-for="Name" class="text-xs text-muted-foreground mb-1 block">Nombre <span class="text-red-400">*</span></label>
                            <input asp-for="Name" placeholder="Nombre del objeto"
                                   class="w-full text-sm font-semibold text-foreground bg-muted/30 px-3 py-2 rounded border border-border focus:outline-none focus:ring-2 focus:ring-ring" />
                            <span asp-validation-for="Name" class="text-red-400 text-xs"></span>
                        </div>

                        <div class="py-2 border-b border-border">
                            <label asp-for="Description" class="text-xs text-muted-foreground mb-1 block">Descripción <span class="text-red-400">*</span></label>
                            <textarea asp-for="Description" rows="4" placeholder="Descripción del objeto (mínimo 20 caracteres)"
                                      class="w-full text-sm text-foreground bg-muted/30 px-3 py-2 rounded border border-border focus:outline-none focus:ring-2 focus:ring-ring"></textarea>
                            <span asp-validation-for="Description" class="text-red-400 text-xs"></span>
                        </div>

                        <div class="py-2 border-b border-border">
                            <label class="text-xs text-muted-foreground mb-1 block">Categorías <span class="text-red-400">*</span></label>

                            <details class="group bg-muted/30 rounded-lg border border-border">
                                <summary class="list-none cursor-pointer px-4 py-3 flex items-center justify-between text-foreground font-semibold text-sm">
                                    <span>Seleccionar una o más categorías</span>
                                    <i class="bi bi-chevron-down text-xs transition-transform group-open:rotate-180"></i>
                                </summary>
                                <div class="px-3 pb-3 pt-1 border-t border-border space-y-2 max-h-52 overflow-y-auto">
                                    @foreach (var cat in categories)
                                    {
                                        var isChecked = selectedCategoryIds.Contains(cat.Id);
                                        <label class="flex items-center gap-3 p-2 rounded-md hover:bg-card cursor-pointer border border-transparent hover:border-border">
                                            <input type="checkbox" name="selectedCategoryIds" value="@cat.Id" @(isChecked ? "checked" : null)
                                                   class="w-4 h-4 rounded border-border bg-muted text-primary focus:ring-ring" />
                                            <span class="text-sm text-foreground">@cat.Description</span>
                                        </label>
                                    }
                                </div>
                            </details>
                        </div>

                        <div class="py-2 border-b border-border">
                            <label asp-for="Condition" class="text-xs text-muted-foreground mb-1 block">Condición</label>
                            <select asp-for="Condition" class="w-full text-sm text-foreground bg-muted/30 px-3 py-2 rounded border border-border focus:outline-none focus:ring-2 focus:ring-ring">
                                <option value="">Seleccione condición</option>
                                <option>Nueva</option>
                                <option>Muy Buena</option>
                                <option>Buena</option>
                                <option>Regular</option>
                            </select>
                            <span asp-validation-for="Condition" class="text-red-400 text-xs"></span>
                        </div>

                        <div class="flex items-center gap-3 py-2 border-b border-border">
                            <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                                <i class="bi bi-check-circle-fill text-foreground text-xs"></i>
                            </div>
                            <div class="flex-1">
                                <div class="text-xs text-muted-foreground">Estado inicial</div>
                                <div class="font-semibold text-foreground text-sm">Activo (no editable)</div>
                            </div>
                        </div>

                        <div class="flex items-center gap-3 py-2">
                            <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                                <i class="bi bi-person-fill text-foreground text-xs"></i>
                            </div>
                            <div class="flex-1">
                                <div class="text-xs text-muted-foreground">Usuario vendedor</div>
                                <div class="font-semibold text-foreground text-sm">@(seller?.Username ?? "Vendedor no disponible")</div>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end gap-3">
                        <a asp-action="Index"
                           class="inline-flex items-center px-5 py-2.5 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-all font-semibold">
                            <i class="bi bi-x-circle mr-2"></i>
                            Cancelar
                        </a>
                        <button type="submit"
                                class="inline-flex items-center px-5 py-2.5 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-all font-semibold shadow-lg">
                            <i class="bi bi-check2-circle mr-2"></i>
                            Guardar Objeto
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="confirmSaveObjectCreateModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4">
    <div class="w-full max-w-md rounded-xl border border-border bg-card shadow-2xl">
        <div class="px-6 py-4 border-b border-border">
            <h3 class="text-lg font-bold text-foreground flex items-center">
                <i class="bi bi-patch-question mr-2 text-primary"></i>
                Confirmar creación
            </h3>
        </div>
        <div class="px-6 py-5 text-sm text-muted-foreground">
            ¿Desea guardar este objeto?
        </div>
        <div class="px-6 py-4 border-t border-border flex justify-end gap-3">
            <button type="button" id="cancelSaveObjectCreateBtn"
                    class="inline-flex items-center px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-muted/80 transition-colors font-semibold">
                Cancelar
            </button>
            <button type="button" id="confirmSaveObjectCreateBtn"
                    class="inline-flex items-center px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:bg-secondary transition-colors font-semibold">
                Guardar
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const form = document.getElementById('objectCreateForm');
            const modal = document.getElementById('confirmSaveObjectCreateModal');
            const cancelBtn = document.getElementById('cancelSaveObjectCreateBtn');
            const confirmBtn = document.getElementById('confirmSaveObjectCreateBtn');
            let confirmed = false;

            if (!form || !modal || !cancelBtn || !confirmBtn) return;

            form.addEventListener('submit', function (e) {
                if (confirmed) return;
                e.preventDefault();
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });

            cancelBtn.addEventListener('click', function () {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            });

            confirmBtn.addEventListener('click', function () {
                confirmed = true;
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                form.submit();
            });

            modal.addEventListener('click', function (e) {
                if (e.target === modal) {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                }
            });
        })();
    </script>
}
