@model La_Galeria_del_Diez.Application.DTOs.Auctionable_ObjectDTO

@{
    ViewData["Title"] = Model.Name;
}

<div class="min-h-screen bg-background py-8">
    <div class="container mx-auto px-4 max-w-6xl">
        <!-- Breadcrumb -->
        <div class="mb-4">
            <a asp-controller="Object" asp-action="Index" 
               class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">
                <i class="bi bi-arrow-left mr-2"></i>
                Volver a Objetos
            </a>
        </div>

        <!-- Título -->
        <h1 class="text-xl font-bold text-foreground mb-4">@Model.Name</h1>

        <!-- BLOQUE SUPERIOR: Imagen (izq) + Info (der) -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
            
            <!-- IZQUIERDA: Imagen principal + miniaturas (1 de 3 columnas) -->
            <div class="lg:col-span-1">
                <!-- Imagen principal -->
                <div class="bg-card rounded-lg border border-border overflow-hidden mb-2">
                    @if (Model.Images.Any())
                    {
                        <div class="bg-muted w-full h-48">
                            <img id="mainImageSrc" 
                                 src="@Url.Action("GetImage", "Image", new { objectId = Model.Id })" 
                                 alt="@Model.Name" 
                                 class="w-full h-full object-contain">
                        </div>
                    }
                    else
                    {
                        <div class="bg-muted w-full h-48 flex items-center justify-center">
                            <i class="bi bi-image text-3xl text-muted-foreground"></i>
                        </div>
                    }
                </div>

                <!-- Miniaturas -->
                @if (Model.Images.Any())
                {
                    <div class="flex gap-2 flex-wrap">
                        @for (int i = 0; i < Model.Images.Count; i++)
                        {
                            var img = Model.Images[i];
                            var thumbUrl = Url.Action("ByImageId", "Image", new { imageId = img.Id, objectId = Model.Id });
                            var isFirst = i == 0;
                            
                            <button type="button"
                                    onclick="changeMainImage('@thumbUrl', this)" 
                                    class="thumbnail-btn w-12 h-12 rounded border-2 transition-all overflow-hidden @(isFirst ? "border-primary" : "border-border hover:border-primary")">
                                <img src="@thumbUrl" alt="Imagen @(i + 1)" class="w-full h-full object-cover">
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- DERECHA: Información del objeto (2 de 3 columnas) -->
            <div class="lg:col-span-2 flex flex-col gap-4 h-full">
                <!-- Bloque de información principal -->
                <div class="bg-card rounded-lg border border-border p-4">
                    
                    <!-- Estado -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-check-circle-fill text-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Estado</div>
                            <div class="font-semibold text-foreground text-sm">@Model.State.Description</div>
                        </div>
                    </div>

                    <!-- Condición -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-star-fill text-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Condición</div>
                            <div class="font-semibold text-foreground text-sm">@(Model.Condition ?? "Nueva")</div>
                        </div>
                    </div>

                    <!-- Fecha de registro -->
                    <div class="flex items-center gap-3 py-2 border-b border-border">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-calendar-check text-foreground text-xs"></i>
                        </div>
                        <div>
                            <div class="text-xs text-muted-foreground">Fecha de registro</div>
                            <div class="font-semibold text-foreground text-sm">@Model.RegistrationDate.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>

                    <!-- Categorías -->
                    @if (Model.Categories.Any())
                    {
                        <div class="flex items-start gap-3 py-2 border-b border-border">
                            <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                                <i class="bi bi-tags-fill text-foreground text-xs"></i>
                            </div>
                            <div class="flex-1">
                                <div class="text-xs text-muted-foreground mb-1">Categorías</div>
                                <div class="flex flex-wrap gap-1.5">
                                    @foreach (var cat in Model.Categories)
                                    {
                                        <span class="px-2 py-1 bg-muted text-foreground rounded text-xs font-medium border border-border">
                                            @cat.Description
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Descripción -->
                    <div class="flex items-start gap-3 py-2">
                        <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-file-text text-foreground text-xs"></i>
                        </div>
                        <div class="flex-1">
                            <div class="text-xs text-muted-foreground mb-1">Descripción</div>
                            <p class="text-foreground leading-relaxed text-sm">
                                @(Model.Description ?? "No hay descripción disponible.")
                            </p>
                        </div>
                    </div>

                </div>

                <!-- BLOQUE: Historial de Subastas -->
                @if (Model.Auctions.Any())
                {
                    <div class="bg-card rounded-lg border border-border overflow-hidden">
                        <div class="bg-muted/30 px-4 py-2.5 border-b border-border">
                            <h2 class="text-sm font-bold text-foreground flex items-center">
                                <i class="bi bi-clock-history mr-2 text-primary text-xs"></i>
                                Historial de Subastas
                            </h2>
                        </div>

                        <div class="divide-y divide-border max-h-32 overflow-y-auto">
                            @foreach (var auction in Model.Auctions.OrderByDescending(a => a.StartDate))
                            {
                                var isActive = auction.EndDate > DateTime.Now;
                                var timeRemaining = auction.EndDate - DateTime.Now;
                                var statusClass = isActive ? "bg-green-500" : "bg-gray-400";
                                var statusText = isActive ? "ACTIVA" : "FINALIZADA";
                                var bidCount = auction.Biddings?.Count ?? 0;
                                var currentPrice = auction.Biddings?.Any() == true 
                                    ? auction.Biddings.Max(b => b.Amount) 
                                    : auction.BasePrice;

                                <div class="p-3 hover:bg-muted/10 transition-colors">
                                    <div class="flex items-center justify-between mb-3">
                                        <span class="@statusClass text-white px-2.5 py-1 rounded-full text-xs font-bold">
                                            @statusText
                                        </span>
                                        @if (isActive && timeRemaining.TotalHours < 24)
                                        {
                                            <span class="text-red-500 text-xs font-bold">
                                                <i class="bi bi-exclamation-triangle mr-1"></i>
                                                ˇQuedan @((int)timeRemaining.TotalHours)h @timeRemaining.Minutes m!
                                            </span>
                                        }
                                    </div>

                                    <div class="flex items-center justify-between gap-4 mb-3">
                                        <div>
                                            <div class="text-xs text-muted-foreground">Inicio</div>
                                            <div class="font-semibold text-foreground text-sm">@auction.StartDate.ToString("dd/MM/yyyy")</div>
                                        </div>
                                        <div>
                                            <div class="text-xs text-muted-foreground">Fin</div>
                                            <div class="font-semibold text-foreground text-sm">@auction.EndDate.ToString("dd/MM/yyyy")</div>
                                        </div>
                                        <div>
                                            <div class="text-xs text-muted-foreground">Precio</div>
                                            <div class="text-base font-bold text-primary">$@currentPrice.ToString("N0")</div>
                                        </div>
                                        <div>
                                            <div class="text-xs text-muted-foreground">Pujas</div>
                                            <div class="font-semibold text-foreground text-base">@bidCount</div>
                                        </div>
                                        <div>
                                            <a asp-controller="Subasta" asp-action="Details" asp-route-id="@auction.Id"
                                               class="inline-flex items-center px-3 py-1.5 bg-primary text-primary-foreground rounded hover:bg-secondary transition-all font-semibold text-xs whitespace-nowrap">
                                                <i class="bi bi-eye mr-1.5"></i>
                                                Ver subasta
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function changeMainImage(src, btn) {
        const img = document.getElementById('mainImageSrc');
        if (img) img.src = src;
        
        document.querySelectorAll('.thumbnail-btn').forEach(b => {
            b.classList.remove('border-primary');
            b.classList.add('border-border');
        });
        
        if (btn) {
            btn.classList.remove('border-border');
            btn.classList.add('border-primary');
        }
    }
</script>
